{
	"_version": "1.81.0",
	"sap.app": {
		"id": "pricelistapp.datamaintain",
		"type": "application",
		"i18n": {
			"bundleUrl": "i18n/i18n.properties",
			"supportedLocales": [
				""
			]
		},
		"applicationVersion": {
			"version": "0.0.1"
		},
		"title": "{{appTitle}}",
		"description": "{{appDescription}}",
		"resources": "resources.json",
		"sourceTemplate": {
			"id": "@sap/generator-fiori:lrop",
			"version": "1.20.1",
			"toolsId": "062c9dca-9de6-43ea-a2cf-9fb2cc69ffb3"
		},
		"dataSources": {
			"mainService": {
				"uri": "/odata/v4/price-list/",
				"type": "OData",
				"settings": {
					"annotations": [],
					"odataVersion": "4.0"
				}
			}
		},
		"crossNavigation": {
			"inbounds": {
				"data_maintenance-manage": {
					"semanticObject": "DataMaintain",
					"action": "manage",
					"title": "{{dataMaintain-manage.flpTitle}}",
					"signature": {
						"parameters": {},
						"additionalParameters": "allowed"
					}
				}
			}
		}
	},
	"sap.ui": {
		"technology": "UI5",
		"icons": {
			"icon": "",
			"favIcon": "",
			"phone": "",
			"phone@2": "",
			"tablet": "",
			"tablet@2": ""
		},
		"deviceTypes": {
			"desktop": true,
			"tablet": true,
			"phone": true
		}
	},
	"sap.ui5": {
		"flexEnabled": true,
		"dependencies": {
			"minUI5Version": "1.144.0",
			"libs": {
				"sap.m": {},
				"sap.ui.core": {},
				"sap.fe.templates": {}
			}
		},
		"contentDensities": {
			"compact": true,
			"cozy": true
		},
		"models": {
			"i18n": {
				"type": "sap.ui.model.resource.ResourceModel",
				"settings": {
					"bundleName": "pricelistapp.datamaintain.i18n.i18n",
					"supportedLocales": [
						""
					]
				}
			},
			"": {
				"dataSource": "mainService",
				"preload": true,
				"settings": {
					"groupId": "$direct",
					"updateGroupId": "$direct",
					"operationMode": "Server",
					"autoExpandSelect": true,
					"earlyRequests": true
				}
			},
			"@i18n": {
				"type": "sap.ui.model.resource.ResourceModel",
				"uri": "i18n/i18n.properties",
				"settings": {
					"supportedLocales": [
						""
					]
				}
			}
		},
		"resources": {
			"css": []
		},
		"routing": {
			"config": {},
			"routes": [
				{
					"name": "TableDirectoryList",
					"pattern": ":?query:",
					"target": "TableDirectoryList"
				}
			],
			"targets": {
				"TableDirectoryList": {
					"type": "Component",
					"id": "TableDirectoryList",
					"name": "sap.fe.core.fpm",
					"options": {
						"settings": {
							"contextPath": "/TableDirectory",
							"navigation": {},
							"viewName": "pricelistapp.datamaintain.ext.view.Main",
							"initialLoad": "Enabled"
						}
					}
				}
			}
		},
		"flexBundle": false
	},
	"sap.fiori": {
		"registrationIds": [],
		"archeType": "transactional"
	},
	"sap.cloud": {
		"public": true,
		"service": "priceListSystem.service"
	}
}